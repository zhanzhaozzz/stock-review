# ============================================================
# Stock Review - 环境配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 基础配置 ----------
APP_NAME=StockReview
APP_ENV=development
# API 端口
API_PORT=8000
# 时区
TZ=Asia/Shanghai

# ---------- 数据库 ----------
# SQLite 路径 (相对于 backend 目录)
DATABASE_URL=sqlite+aiosqlite:///./data/stock_review.db

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Redis 密码 (可选)
# REDIS_PASSWORD=

# ---------- 数据源: Tushare ----------
# 注册: https://tushare.pro/register
# 低积分(120)即可用: daily, daily_basic, index_daily, trade_cal
TUSHARE_TOKEN=

# ---------- 数据源优先级 ----------
# A股日线: akshare > tushare > efinance
# 港股: akshare
# 实时行情: tencent > sina
DATA_PROVIDER_PRIORITY=akshare,tushare,efinance

# ---------- LLM 配置 (LiteLLM) ----------
# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com

# 智谱 GLM
ZHIPU_API_KEY=

# Kimi / Moonshot
MOONSHOT_API_KEY=

# 通义千问
DASHSCOPE_API_KEY=

# 评级引擎: 多模型并行
RATING_LLM_MODELS=deepseek/deepseek-chat,zhipu/glm-4-flash,moonshot/moonshot-v1-8k
RATING_LLM_WEIGHTS=0.4,0.3,0.3

# 分析报告: 用最强模型
ANALYSIS_LLM_MODEL=deepseek/deepseek-chat

# 新闻过滤 + 复盘辅助: 用最便宜模型
UTILITY_LLM_MODEL=zhipu/glm-4-flash

# ---------- JWT 认证 ----------
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 默认管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---------- 定时任务 ----------
# 收盘后自动刷新时间 (24h 格式, 北京时间)
REFRESH_HOUR=15
REFRESH_MINUTE=30

# ---------- 缓存策略 ----------
# 交易时段缓存秒数
CACHE_TTL_TRADING=60
# 非交易时段缓存秒数
CACHE_TTL_NON_TRADING=300
